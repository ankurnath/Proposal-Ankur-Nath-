@article{vrij-clt,
title = "A cognitive load approach to lie detection",
abstract = "We present two lie detection approaches based on cognitive theory. The first approach, {\textquoteleft}measuring cognitive load{\textquoteright}, assumes that the mere act of lying generates observable signs of cognitive load. This is the traditional cognitive lie detection approach formulated by Zuckerman, DePaulo, & Rosenthal (1981). The second approach, {\textquoteleft}imposing cognitive load{\textquoteright}, was developed by us (Vrij, Fisher, Mann, & Leal, 2006) and goes one step further. Here, the lie detector attempts to actively increase the differences between lying and truth telling by introducing mentally taxing interventions. We assume that people require more cognitive resources when they lie than when they tell the truth to produce their statements, and therefore will have fewer cognitive resources left over to address these mentally taxing interventions when they lie than when they tell the truth. This should result in more pronounced differences between lying and truth telling in terms of displaying stronger signs of cognitive load. We provide empirical support for this approach: Observers can discriminate better between lying and truth telling when interviewers actively impose mentally taxing interventions.",
author = "Aldert Vrij and R. Fisher and Samantha Mann and Sharon Leal",
year = "2008",
doi = "10.1002/jip.82",
language = "English",
volume = "5",
pages = "39--43",
journal = "Journal of Investigative Psychology and Offender Profiling",
issn = "1544-4759",
publisher = "John Wiley and Sons Ltd",
number = "1-2",
}

@article{vrij2,
author = {Vrij, Aldert and Fisher, Ronald P. and Blank, Hartmut},
title = {A cognitive approach to lie detection: A meta-analysis},
journal = {Legal and Criminological Psychology},
volume = {22},
number = {1},
pages = {1-21},
keywords = {lie detection, interviewing to detect deception, cognition, meta-analysis},
doi = {https://doi.org/10.1111/lcrp.12088},
url = {https://bpspsychub.onlinelibrary.wiley.com/doi/abs/10.1111/lcrp.12088},
eprint = {https://bpspsychub.onlinelibrary.wiley.com/doi/pdf/10.1111/lcrp.12088},
abstract = {Introduction This article provides a meta-analysis of a new, cognitive approach to (non-)verbal lie detection. This cognitive lie detection approach consists of three techniques: (1) imposing cognitive load, (2) encouraging interviewees to say more, and (3) asking unexpected questions. Method A meta-analysis was carried out on studies using the cognitive approach, 14 of which directly compared the cognitive approach to a standard approach. Results The cognitive lie detection approach produced superior accuracy results in truth detection (67\%), lie detection (67\%), and total detection (truth and lie detection combined, 71\%) compared to a traditional standard approach (truth detection: 57\%; lie detection: 47\%; total detection: 56\%). Conclusions Practitioners may find it useful to use a cognitive lie detection approach in their daily practice.},
year = {2017}
}

@article{buller-idt,
author = {Buller, David B. and Burgoon, Judee K.},
title = {Interpersonal Deception Theory},
journal = {Communication Theory},
volume = {6},
number = {3},
pages = {203-242},
doi = {https://doi.org/10.1111/j.1468-2885.1996.tb00127.x},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1468-2885.1996.tb00127.x},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/j.1468-2885.1996.tb00127.x},
abstract = {Interpersonal deception theory (IDT) represents a merger of interpersonal communication and deception principles designed to better account for deception in interactive contexts. At the same time, it bas the potential to enlighten theories related to (a) credibility and truthful communication and (b) interpersonal communication. Presented here are key definitions, assumptions related to the critical attributes and key features of interpersonal communication and deception, and 18 general propositions from which specific testable hypotheses can be derived. Research findings relevant to the propositions are also summarized.},
year = {1996}
}

